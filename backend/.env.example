# StockPulse Backend Environment Configuration
# Copy this file to .env and fill in your values

# ==================== MongoDB ====================
# Primary entity/document store for user data, stock data, pipeline records
# For local development: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/stockpulse
MONGO_URL=mongodb://localhost:27017

# Database Name
MONGO_DB_NAME=stockpulse

# ==================== Redis ====================
# Hot cache layer for live prices, analysis results, session data
# For local development: redis://localhost:6379
# For Redis Cloud: redis://username:password@host:port
# For TLS (managed Redis): rediss://username:password@host:port
REDIS_URL=redis://localhost:6379

# Redis connection tuning (optional — sensible defaults are used)
# REDIS_CONNECT_TIMEOUT=5      # Connection timeout in seconds (default: 5)
# REDIS_SOCKET_TIMEOUT=5       # Socket read/write timeout in seconds (default: 5)
# REDIS_MAX_CONNECTIONS=10     # Max connections in pool (default: 10)
# REDIS_FALLBACK_MAX_KEYS=10000  # Max keys in in-memory fallback cache (default: 10000)
# REDIS_KEY_PREFIX=stockpulse:   # Namespace prefix for all Redis keys (default: stockpulse:)
# REDIS_SSL=false               # Set to true when using TLS (rediss://); URL must use rediss:// scheme

# Cache flush protection (default: disabled in production)
# ALLOW_CACHE_FLUSH=false

# TLS/SSL certificate paths (only needed for self-signed or mTLS setups)
# For managed Redis (e.g., Redis Cloud, ElastiCache), just use "rediss://" in REDIS_URL.
# REDIS_SSL_CA_CERTS=/path/to/ca-cert.pem
# REDIS_SSL_CERTFILE=/path/to/client-cert.pem
# REDIS_SSL_KEYFILE=/path/to/client-key.pem

# ==================== PostgreSQL ====================
# Time-series & analytical layer for OHLCV prices, technicals, fundamentals
# For local development: postgresql://localhost:5432/stockpulse_ts
# For cloud: postgresql://username:password@host:port/stockpulse_ts
TIMESERIES_DSN=postgresql://localhost:5432/stockpulse_ts

# Macro indicators job (optional): override RBI/CPI/IIP when no API; yfinance used for FX/commodities
# MACRO_RBI_REPO_RATE=6.5
# MACRO_CPI_INFLATION=4.2
# MACRO_IIP_GROWTH=3.1
# MACRO_STEEL_TICKER=  # yfinance ticker for steel if desired

# ==================== Data Sources ====================
# Groww API credentials (for TOTP-based authentication)
GROW_TOTP_TOKEN=
GROW_SECRET_KEY=

# Yahoo Finance (via yfinance - no API key needed)
# Set to 'true' to use real market data, 'false' for mock data
USE_REAL_DATA=true

# ==================== LLM / AI ====================
# Emergent LLM API Key for AI-powered insights
EMERGENT_LLM_KEY=your_emergent_llm_key_here

# Google Generative AI API Key (alternative LLM)
GOOGLE_API_KEY=

# ==================== Server ====================
# CORS Origins (comma-separated list of allowed frontend URLs)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Environment (development/production)
ENVIRONMENT=development

# ==================== Filesystem Paths ====================
# Directories for binary artifacts (auto-created if missing)
REPORTS_DIR=./reports
BHAVCOPY_DIR=./data/bhavcopy
MODELS_DIR=./models
BACKUPS_DIR=./backups
